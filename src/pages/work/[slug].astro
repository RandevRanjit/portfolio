---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetricBlock from '../../components/MetricBlock.astro';
import AsciiAnim from '../../components/AsciiAnim.astro';
import TermRule from '../../components/TermRule.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const all = await getCollection('projects');
  return all.map((p) => ({ params: { slug: p.id }, props: { p } }));
}
const { p } = Astro.props;
const { Content } = await render(p);
const d = p.data;
const lineage = d.lineage ?? [];
---
<BaseLayout title={d.title} description={d.tagline} section={d.section}>
  <article class="wrap reveal" style="padding-block:2.5rem 3.5rem; max-width:52rem;">
    <p class="section-num">{String(d.order).padStart(2, '0')} / {d.buckets.join(' · ').toUpperCase()}</p>
    <h1 style="font-size:var(--fs-h1)">{d.title}</h1>
    <p style="font-size:1.25rem">{d.tagline}</p>
    <AsciiAnim slug={p.id} size="hero" />
    <ul class="stack">{d.stack.map((s) => <li class="label">{s}</li>)}</ul>
    <MetricBlock metrics={d.metrics} />
    {d.images.map((im) => (
      <figure><img src={im.src} alt={im.alt} loading="lazy" />{im.caption && <figcaption class="label">{im.caption}</figcaption>}</figure>
    ))}
    <div class="prose"><Content /></div>
    <div style="margin-top:2rem;"><TermRule /></div>
    <p class="label">ROLE</p><p>{d.role}</p>
    <p class="label">DATES / {d.dates}</p>
    {d.repo.kind === 'public' && d.repo.url && <p><a href={d.repo.url}>View source on GitHub →</a></p>}
    {d.repo.kind !== 'public' && <p class="label">{d.repo.kind === 'private' ? 'Private repository' : 'Case study — private UoM coursework, no code link'}</p>}
    {lineage.length > 0 && (
      <div class="lineage">
        <p class="label">RELATED LINEAGE</p>
        <ul>
          {lineage.map((l) => (
            <li><a href={withBase(`work/${l.slug}`)}>{l.note} →</a></li>
          ))}
        </ul>
      </div>
    )}
  </article>
</BaseLayout>
<style>
  .stack { display:flex; flex-wrap:wrap; gap:.5rem; list-style:none; padding:0; margin:1rem 0; }
  .prose :global(p) { margin: 1rem 0; }
  .prose :global(h2) { font-size: var(--fs-h2); margin: 2.25rem 0 .75rem; }
  .prose :global(h3) { font-size: var(--fs-h3); margin: 1.75rem 0 .5rem; }
  .prose :global(ul), .prose :global(ol) { margin: 1rem 0; padding-left: 1.25rem; }
  .prose :global(li) { margin: .35rem 0; }
  .prose :global(li::marker) { color: var(--accent); }
  /* inline code */
  .prose :global(:not(pre) > code) {
    font-family: var(--font-mono); font-size: .92em;
    background: var(--paper-2); border: 1px solid var(--line);
    padding: .05rem .3rem; border-radius: 0;
  }
  /* fenced code block — terminal panel with accent left edge + prompt */
  .prose :global(pre) {
    font-family: var(--font-mono); font-size: .86rem; line-height: 1.5;
    background: var(--paper-2); color: var(--astro-code-foreground);
    border: 2px solid var(--ink); border-left: 6px solid var(--accent);
    padding: 1rem 1.1rem; margin: 1.25rem 0; overflow-x: auto;
  }
  .prose :global(pre) :global(code) { font-family: var(--font-mono); background: none; border: 0; padding: 0; }
  /* tables — booktabs-ish, no vertical rules */
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.25rem 0; font-size: .92rem; }
  .prose :global(th), .prose :global(td) { text-align: left; padding: .5rem .75rem; border-bottom: 2px solid var(--line); }
  .prose :global(thead) :global(th) { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .05em; font-size: .78rem; color: var(--grey); border-bottom: var(--rule) solid var(--ink); }
  figure { margin: 1.5rem 0; } img { max-width:100%; height:auto; border:2px solid var(--ink); }
  .lineage { margin-top: 1.5rem; border-left: 6px solid var(--accent); padding-left: 1rem; }
  .lineage ul { list-style: none; padding: 0; margin: .25rem 0 0; font-family: var(--font-mono); font-size: .9rem; }
  .lineage li { margin: .3rem 0; }
</style>
