---
// src/components/AsciiAnim.astro
// Decorative per-project ASCII animation. aria-hidden, purely visual.
// One bespoke engine per project slug — see ../lib/ascii-engines.ts.
// SSR renders the static first frame (tick 0); the client script animates
// it (cards on hover, hero while in view; static under reduced-motion).
import { asciiFirstFrame } from '../lib/ascii-engines';

interface Props {
  slug: string;
  size: 'card' | 'hero';
}
const { slug, size } = Astro.props;

// Card dims: 16 cols × 6 rows. Hero dims: 40 cols × 10 rows.
const cols = size === 'hero' ? 40 : 16;
const rows = size === 'hero' ? 10 : 6;

const firstFrame = asciiFirstFrame(slug, cols, rows);
---

<pre class="ascii-anim" data-slug={slug} data-size={size} aria-hidden="true">{firstFrame}</pre>

<style>
  .ascii-anim {
    font-family: var(--font-display);
    font-size: clamp(0.5rem, 1.4vw, 0.72rem);
    line-height: 1.3;
    color: var(--accent);
    white-space: pre;
    overflow: hidden;
    margin: 0;
    display: block;
    /* card: fixed dims so it never blows out the grid */
    max-width: 100%;
  }
  .ascii-anim[data-size='card'] {
    font-size: 0.62rem;
    line-height: 1.2;
    height: 5rem;            /* fixed slot → card titles line up across the row */
    display: grid;
    place-items: center;     /* centre the ASCII block horizontally + vertically */
    margin: 0.25rem 0 1rem;
    overflow: hidden;
  }
  .ascii-anim[data-size='hero'] {
    font-size: clamp(0.6rem, 1.5vw, 0.85rem);
    margin: 0 auto 1.5rem;   /* centre the block in the article */
    width: fit-content;
    max-width: 100%;
    opacity: 0.85;
  }
</style>

<script>
// AsciiAnim runtime — boots all .ascii-anim elements, one bespoke engine each
// (looked up by data-slug). ~10 fps; pauses off-screen; cards animate on hover.
import { engines, type AsciiEngine } from '../lib/ascii-engines';

(function () {
  'use strict';

  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  interface Inst {
    engine: AsciiEngine;
    interval: ReturnType<typeof setInterval> | null;
    t: number;
    inView: boolean;
    hovered: boolean;
  }

  function bootAll() {
    const els = document.querySelectorAll<HTMLPreElement>('.ascii-anim');
    if (!els.length) return;

    const instances = new Map<HTMLPreElement, Inst>();

    function makeEngine(el: HTMLPreElement): AsciiEngine {
      const slug = el.dataset.slug || '';
      const size = el.dataset.size || 'card';
      const cols = size === 'hero' ? 40 : 16;
      const rows = size === 'hero' ? 10 : 6;
      const factory = engines[slug] || engines._default;
      return factory(cols, rows);
    }

    function startAnim(el: HTMLPreElement) {
      const inst = instances.get(el);
      if (!inst || inst.interval) return;
      inst.interval = setInterval(() => {
        inst.t++;
        el.textContent = inst.engine.tick(inst.t);
      }, 100); // ~10 fps
    }

    function stopAnim(el: HTMLPreElement) {
      const inst = instances.get(el);
      if (!inst || !inst.interval) return;
      clearInterval(inst.interval);
      inst.interval = null;
    }

    function shouldAnimate(inst: Inst, size: string) {
      if (size === 'card') return inst.inView && inst.hovered;
      return inst.inView; // hero: animate while in view
    }

    els.forEach((el) => {
      const engine = makeEngine(el);
      const size = el.dataset.size || 'card';

      instances.set(el, { engine, interval: null, t: 0, inView: false, hovered: false });

      if (REDUCED) return; // static — no animation at all

      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const inst = instances.get(el);
          if (!inst) return;
          inst.inView = entry.isIntersecting;
          if (shouldAnimate(inst, size)) startAnim(el);
          else stopAnim(el);
        });
      }, { threshold: 0.1 });
      io.observe(el);

      if (size === 'card') {
        el.addEventListener('mouseenter', () => {
          const inst = instances.get(el);
          if (!inst) return;
          inst.hovered = true;
          if (shouldAnimate(inst, size)) startAnim(el);
        });
        el.addEventListener('mouseleave', () => {
          const inst = instances.get(el);
          if (!inst) return;
          inst.hovered = false;
          stopAnim(el);
        });
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootAll);
  } else {
    bootAll();
  }
})();
</script>
