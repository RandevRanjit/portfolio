---
import { sectionNav, site } from '../data/site';
import { withBase } from '../lib/url';
const { current } = Astro.props as { current?: string };
---
<nav class="nav wrap">
  <a class="nav__home" href={withBase('')}>{site.name}</a>
  <div class="nav__right">
    <ul class="nav__sections">
      {sectionNav.map((s) => (
        <li><a href={withBase(s.href)} class:list={['chip', `chip--${s.id}`, { 'chip--on': current === s.id }]}>{s.label}</a></li>
      ))}
    </ul>
    <button id="theme-toggle" class="chip chip--theme" aria-label="Toggle colour theme" aria-pressed="false">[DARK]</button>
  </div>
</nav>
<style>
  .nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: 1rem; flex-wrap: wrap; }
  .nav__home { font-family: var(--font-display); font-weight: 400; text-decoration: none; font-size: 1.15rem; }
  .nav__right { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
  .nav__sections { display: flex; gap: .5rem; list-style: none; margin: 0; padding: 0; flex-wrap: wrap; }
  .chip { font-family: var(--font-mono); font-size: var(--fs-label); text-transform: uppercase; letter-spacing: .06em;
          text-decoration: none; padding: .35rem .6rem; border: 2px solid var(--ink); display: inline-block;
          color: var(--ink); background: transparent; cursor: pointer; }
  .chip--quant:hover, .chip--quant.chip--on { background: var(--accent-quant); color: var(--paper); border-color: var(--accent-quant); }
  .chip--drones:hover, .chip--drones.chip--on { background: var(--accent-drones); color: var(--paper); border-color: var(--accent-drones); }
  .chip--motorsport:hover, .chip--motorsport.chip--on { background: var(--accent-motorsport); color: var(--paper); border-color: var(--accent-motorsport); }
  .chip--music:hover, .chip--music.chip--on { background: var(--accent-music); color: var(--paper); border-color: var(--accent-music); }
  .chip--other:hover, .chip--other.chip--on { background: var(--accent-other); color: var(--paper); border-color: var(--accent-other); }
  .chip--theme:hover { background: var(--ink); color: var(--paper); }
</style>
