---
import { spokeNav, site } from '../data/site';
const { current } = Astro.props as { current?: string };
---
<nav class="nav wrap">
  <a class="nav__home" href="/">{site.name}</a>
  <div class="nav__right">
    <ul class="nav__spokes">
      {spokeNav.map((s) => (
        <li><a href={s.href} class:list={['chip', `chip--${s.id}`, { 'chip--on': current === s.id }]}>{s.label}</a></li>
      ))}
    </ul>
    <button id="theme-toggle" class="chip chip--theme" aria-label="Toggle colour theme" aria-pressed="false">[DARK]</button>
  </div>
</nav>
<style>
  .nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: 1rem; flex-wrap: wrap; }
  .nav__home { font-family: var(--font-display); font-weight: 800; text-decoration: none; font-size: 1.15rem; }
  .nav__right { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
  .nav__spokes { display: flex; gap: .5rem; list-style: none; margin: 0; padding: 0; flex-wrap: wrap; }
  .chip { font-family: var(--font-mono); font-size: var(--fs-label); text-transform: uppercase; letter-spacing: .06em;
          text-decoration: none; padding: .35rem .6rem; border: 2px solid var(--ink); display: inline-block;
          color: var(--ink); background: transparent; cursor: pointer; }
  .chip--finance:hover, .chip--finance.chip--on { background: var(--accent-finance); color: #fff; border-color: var(--accent-finance); }
  .chip--drone:hover, .chip--drone.chip--on { background: var(--accent-drone); color: #fff; border-color: var(--accent-drone); }
  .chip--motorsport:hover, .chip--motorsport.chip--on { background: var(--accent-motor); color: #fff; border-color: var(--accent-motor); }
  .chip--theme:hover { background: var(--ink); color: var(--paper); }
</style>
