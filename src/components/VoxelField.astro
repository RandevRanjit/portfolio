---
// src/components/VoxelField.astro — pixelated quantised-noise backdrop.
// A 2-D simplex field (Ashima port) posterised into 5 ink-alpha bands and
// drawn at 1 canvas px per voxel, CSS-upscaled with image-rendering:pixelated
// so the bands read as chunky device pixels. Decorative only: aria-hidden,
// pauses off-screen, static single frame under reduced-motion.
// Default: fills a position:relative parent. `fixed`: viewport-wide page
// backdrop behind all content (z-index -1; solid-background panels occlude it).
interface Props { fixed?: boolean }
const { fixed = false } = Astro.props;
---
<canvas class:list={['voxel-field', { 'voxel-field--fixed': fixed }]} aria-hidden="true"></canvas>

<style>
  .voxel-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    pointer-events: none;
    /* renderer reads this computed color → bands follow the theme */
    color: var(--ink);
  }
  .voxel-field--fixed {
    position: fixed;
    z-index: -1;
  }
</style>

<script>
// Voxel-field runtime — ~10 fps stepped time (matches AsciiAnim cadence),
// IntersectionObserver pause, theme-reactive ink via computed `color`.

const VOXEL = 10;           // CSS px per voxel — chunky, reads as device pixels
const LEVELS = 5;           // posterisation bands (shader's `iterations`)
const MAX_ALPHA = 0.12;     // strongest band — must stay subtle behind text
const ALPHA_CURVE = 1.5;    // band → alpha exponent: crisp cores, faint rings
const NOISE_SCALE = 0.03;   // noise-space units per voxel (feature size — lower = larger blobs)
const TICK_MS = 100;
const TIME_STEP = 0.016;    // scaled with NOISE_SCALE so apparent drift speed is unchanged

const REDUCED_MQ = window.matchMedia('(prefers-reduced-motion: reduce)');

function mod289(x: number): number { return x - Math.floor(x * (1 / 289)) * 289; }
function permute(x: number): number { return mod289((x * 34 + 1) * x); }
function fract(x: number): number { return x - Math.floor(x); }

// Direct port of Ashima's GLSL snoise(vec2), scalarised.
function snoise(vx: number, vy: number): number {
  const Cx = 0.211324865405187, Cy = 0.366025403784439,
        Cz = -0.577350269189626, Cw = 0.024390243902439;
  const s = (vx + vy) * Cy;
  let ix = Math.floor(vx + s), iy = Math.floor(vy + s);
  const t = (ix + iy) * Cx;
  const x0x = vx - ix + t, x0y = vy - iy + t;
  const i1x = x0x > x0y ? 1 : 0, i1y = 1 - i1x;
  const x1x = x0x + Cx - i1x, x1y = x0y + Cx - i1y;
  const x2x = x0x + Cz, x2y = x0y + Cz;
  ix = mod289(ix); iy = mod289(iy);
  const p0 = permute(permute(iy) + ix);
  const p1 = permute(permute(iy + i1y) + ix + i1x);
  const p2 = permute(permute(iy + 1) + ix + 1);
  const corner = (p: number, dx: number, dy: number): number => {
    let m = Math.max(0.5 - (dx * dx + dy * dy), 0);
    m *= m; m *= m;
    const x = 2 * fract(p * Cw) - 1;
    const h = Math.abs(x) - 0.5;
    const a0 = x - Math.floor(x + 0.5);
    m *= 1.79284291400159 - 0.85373472095314 * (a0 * a0 + h * h);
    return m * (a0 * dx + h * dy);
  };
  return 130 * (corner(p0, x0x, x0y) + corner(p1, x1x, x1y) + corner(p2, x2x, x2y));
}

// GLSL level(): how many of the 5 band thresholds sit at/above source.
function level(source: number): number {
  let val = 0;
  for (let i = 0; i < LEVELS; i++) if (i / LEVELS >= source) val++;
  return val / LEVELS;
}

function boot(canvas: HTMLCanvasElement) {
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  let cols = 0, rows = 0;
  let img: ImageData | null = null;
  let inkR = 0, inkG = 0, inkB = 0;
  let time = 0;
  let interval: ReturnType<typeof setInterval> | null = null;
  let inView = false;

  function readInk() {
    const m = getComputedStyle(canvas).color.match(/[\d.]+/g);
    if (m && m.length >= 3) { inkR = +m[0]; inkG = +m[1]; inkB = +m[2]; }
  }

  function draw() {
    if (!img || !ctx) return;
    const d = img.data;
    let k = 0;
    for (let gy = 0; gy < rows; gy++) {
      for (let gx = 0; gx < cols; gx++) {
        const nx = gx * NOISE_SCALE, ny = gy * NOISE_SCALE;
        const t = snoise(nx, ny) + snoise(nx + time, ny + time);
        const l = Math.hypot(gx / cols, gy / rows);
        // inverted vs the shader: ink islands on clean paper, not bright-field
        // (level()'s val=1 plateau covers ~half the area — as ink it reads as mud)
        const band = 1 - level(t * l);
        const a = Math.round(Math.pow(band, ALPHA_CURVE) * MAX_ALPHA * 255);
        d[k++] = inkR; d[k++] = inkG; d[k++] = inkB; d[k++] = a;
      }
    }
    ctx.putImageData(img, 0, 0);
  }

  function resize() {
    if (!ctx) return;
    cols = Math.max(1, Math.ceil(canvas.clientWidth / VOXEL));
    rows = Math.max(1, Math.ceil(canvas.clientHeight / VOXEL));
    canvas.width = cols;
    canvas.height = rows;
    img = ctx.createImageData(cols, rows);
    draw();
  }

  function start() {
    if (interval || REDUCED_MQ.matches || !inView) return;
    interval = setInterval(() => { time += TIME_STEP; draw(); }, TICK_MS);
  }
  function stop() {
    if (!interval) return;
    clearInterval(interval);
    interval = null;
  }

  readInk();
  resize();

  new ResizeObserver(resize).observe(canvas);
  new MutationObserver(() => { readInk(); draw(); })
    .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      inView = e.isIntersecting;
      if (inView) start(); else stop();
    });
  }, { threshold: 0.05 }).observe(canvas);

  // react to a mid-session OS reduce-motion toggle (static frame stays drawn)
  REDUCED_MQ.addEventListener('change', () => {
    if (REDUCED_MQ.matches) stop(); else start();
  });
}

function bootAll() {
  document.querySelectorAll<HTMLCanvasElement>('canvas.voxel-field').forEach(boot);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', bootAll);
} else {
  bootAll();
}
</script>
