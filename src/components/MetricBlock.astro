---
// src/components/MetricBlock.astro — robust wrapping metric chips (source = hover tooltip).
// Flexbox with flex-grow so every row fills the full width — including a partial last
// row (a lone trailing chip stretches edge-to-edge instead of sitting at one column).
const { metrics } = Astro.props as { metrics: { label: string; value: string; source: string }[] };
---
<dl class="metrics">
  {metrics.map((m) => (
    <div class="metric" title={`source: ${m.source}`}>
      <dt class="metric__l">{m.label}</dt>
      <dd class="metric__v">{m.value}</dd>
    </div>
  ))}
</dl>
<style>
  .metrics { display: flex; flex-wrap: wrap; gap: .6rem; margin: 1.25rem 0; padding: 0; }
  .metric {
    flex: 1 1 11rem; min-width: 8rem;
    display: flex; flex-direction: column; gap: .35rem;
    border: 2px solid var(--ink); padding: .6rem .8rem; margin: 0;
  }
  .metric__l {
    font-family: var(--font-mono); font-size: .66rem; text-transform: uppercase;
    letter-spacing: .07em; color: var(--grey); margin: 0; line-height: 1.3;
  }
  .metric__v {
    font-family: var(--font-mono); font-size: 1.02rem; font-weight: 600;
    color: var(--accent); margin: 0; line-height: 1.25; overflow-wrap: anywhere;
  }
</style>
